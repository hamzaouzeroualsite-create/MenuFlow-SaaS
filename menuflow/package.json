{
  "name": "menuflow",
  "version": "1.0.0",
  "private": true,
  "description": "MenuFlow - Plateforme SaaS premium de menus digitaux pour restaurants",
  "workspaces": [
    "apps/web",
    "functions"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@menuflow/web",
    "build": "npm run build --workspace=@menuflow/web",
    "start": "npm run start --workspace=@menuflow/web",
    "lint": "npm run lint --workspace=@menuflow/web",
    "firebase:deploy": "firebase deploy",
    "firebase:rules": "firebase deploy --only firestore:rules,storage",
    "functions:build": "npm run build --workspace=menuflow-functions",
    "functions:deploy": "firebase deploy --only functions"
  },
  "devDependencies": {}
  "engines": {
    "node": ">=20.0.0"
  }
}
